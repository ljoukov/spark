rules_version = '2';

service cloud.firestore {
  // Helpers
  function isOwner(userId) {
    return request.auth != null && request.auth.uid == userId;
  }

  match /databases/{database}/documents {
    // Example user-scoped doc
    match /users/{userId}/toons/client {
      allow read: if isOwner(userId);
    }

    // Spark AI Agent runs + workspaces (client read-only)
    match /users/{userId}/agents/{docId=**} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /users/{userId}/workspace/{docId=**} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    // Spark user-scoped docs and subcollections (sessions, graderRuns, docs, etc.)
    match /spark/{userId}/{docId=**} {
      allow read: if isOwner(userId);
    }

    match /spark/{userId}/state/{docId=**} {
      allow read, write: if isOwner(userId);
    }

    // Spark AI Agent client-safe conversations
    match /{userId}/client/{docId=**} {
      allow read: if isOwner(userId);
      allow write: if false;
    }
  }
}
